{
  "manifest_version": 3,
  "name": "DeQueue",
  "version": "1.1.0",
  "description": "Knapsack-powered reading queue for ADHD brains. Set a time budget, get your best items.",

  "options_page": "src/options/options.html",

  "permissions": ["storage", "activeTab", "scripting"],

  "browser_specific_settings": {
    "gecko": {
      "id": "dequeue@lordzed86.example",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DeQueue"
  },

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
